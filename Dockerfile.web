# Build stage for Angular Web App
FROM node:20-alpine AS web-builder

WORKDIR /app/web/pulama-farm

COPY package*.json ./
RUN npm install

COPY . .

# Build production app with proxy config
RUN ng build --configuration=production --output=dist/pulama-farm

# Nginx base image for serving the web app
FROM nginx:alpine

# Copy custom nginx config for reverse proxy
COPY nginx.conf /etc/nginx/conf.d/default.conf

# Copy Angular build output to nginx html directory
COPY --from=web-builder /app/web/pulama-farm/dist/pulama-farm/browser /usr/share/nginx/html/

EXPOSE 8080

CMD ["nginx", "-g", "daemon off;"]